# EditorConfig � IntelliJ, VS Code e demais editores
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{json,jsonc}]
indent_size = 4

[Makefile]
indent_style = tab

[*.java]
indent_size = 4

[*.{ts,tsx,js,mjs,cjs,jsx}]
indent_size = 4

[*.sql]
indent_size = 4
