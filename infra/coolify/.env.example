# Variaveis para o Coolify (Environment / Shared Variables do projeto).
# Nao commitar valores reais. Gere segredos fortes (openssl rand -base64 32).

# --- PostgreSQL ---
POSTGRES_DB=gommo
POSTGRES_USER=gommo
POSTGRES_PASSWORD=

# --- Segredos ---
JWT_SECRET=
NEXTAUTH_SECRET=

# --- URLs publicas (HTTPS apos configurar dominio no Coolify) ---
# HR (colaboradores)
HR_NEXTAUTH_URL=https://app.seudominio.com.br
NEXT_PUBLIC_API_URL=https://api.seudominio.com.br
CORS_ORIGINS=https://app.seudominio.com.br,https://admin.seudominio.com.br

# Admin (plataforma)
ADMIN_NEXTAUTH_URL=https://admin.seudominio.com.br
ADMIN_AUTH_URL=https://admin.seudominio.com.br
NEXT_PUBLIC_ADMIN_API_URL=https://admin-api.seudominio.com.br
NEXT_PUBLIC_HR_API_URL=https://api.seudominio.com.br
ADMIN_CORS_ORIGINS=https://admin.seudominio.com.br

# --- Storage (HR) ---
STORAGE_BUCKET=gommo-prod
