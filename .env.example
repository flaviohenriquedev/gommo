# Copie para .env na raiz do monorepo (docker compose)
POSTGRES_DB=gommo
POSTGRES_USER=gommo
POSTGRES_PASSWORD=defina-uma-senha-local-forte

# Backend (gommo-backend/.env ou variáveis de ambiente)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gommo
DB_USER=gommo
DB_PASSWORD=mesma-senha-do-postgres-acima
JWT_SECRET=defina-minimo-32-caracteres-aleatorios
DEV_ADMIN_PASSWORD=defina-senha-do-usuario-admin-dev
CORS_ORIGINS=http://localhost:3000
SERVER_PORT=8081
