# Copie para .env na raiz:  copy .env.example .env
# O Docker Compose le automaticamente o .env da raiz para substituir ${POSTGRES_PASSWORD}.

POSTGRES_DB=gommo
POSTGRES_USER=gommo
POSTGRES_PASSWORD=gommo_dev

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gommo
DB_USER=gommo
DB_PASSWORD=gommo_dev

JWT_SECRET=altere-para-minimo-32-caracteres-aleatorios
DEV_ADMIN_PASSWORD=altere-senha-do-admin-dev
NEXTAUTH_SECRET=altere-para-minimo-32-caracteres-aleatorios

# gommo-backend (HR)
CORS_ORIGINS=http://localhost:3000,http://*.localhost:3000,http://localhost:3001
SERVER_PORT=8081
GOMMO_STORAGE_MAX_FILE_SIZE=25MB
GOMMO_STORAGE_MAX_REQUEST_SIZE=30MB
# OCR holerites (dev local): baixe com scripts/download-tesseract-por.ps1 ou defina caminho do tessdata
# TESSDATA_PREFIX=../data/tessdata

# gommo-admin-backend
ADMIN_SERVER_PORT=8082
ADMIN_CORS_ORIGINS=http://localhost:3001
TENANT_DB_FALLBACK_PASSWORD=gommo_dev

# Multi-tenant (HR — ver docs/arquitetura/multi-tenant-dev.md)
GOMMO_MULTI_TENANT_ENABLED=true
GOMMO_TENANT_HEADER_ENABLED=true
GOMMO_TENANT_BASE_DOMAIN=localhost

# gommo-frontend: variaveis NEXT_PUBLIC_* ficam em gommo-frontend/.env.local
# NEXT_PUBLIC_MULTI_TENANT_ENABLED=true
